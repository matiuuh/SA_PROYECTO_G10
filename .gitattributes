# Forzar LF en todos los archivos de texto para evitar problemas en contenedores Linux
* text=auto eol=lf

# Shell scripts SIEMPRE en LF (el shebang #!/bin/bash\r rompe en Linux)
*.sh text eol=lf

# SQL — LF
*.sql text eol=lf

# Proto — LF
*.proto text eol=lf

# Binarios — sin conversión
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
